# ============================================================
# Admorph - Environment Variables
# Copy to .env and fill in your values. Never commit .env.
# ============================================================

# ── AI Models ────────────────────────────────────────────────
# Google AI Studio API key (https://aistudio.google.com/)
GOOGLE_API_KEY=your_google_ai_studio_api_key_here

# Gemini model for personalization diff generation
GEMINI_PRO_MODEL=gemini-3.1-pro-preview

# Gemini model for fast ad analysis
GEMINI_FLASH_MODEL=gemini-3-flash-preview

# ── Security ─────────────────────────────────────────────────
# Secret key for JWT signing - must be strong random string (32+ chars)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_with_strong_random_secret_min_32_chars

# JWT algorithm (HS256 recommended)
JWT_ALGORITHM=HS256

# JWT expiry in minutes
JWT_EXPIRY_MINUTES=60

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated allowed origins (no trailing slash)
# Example: http://localhost:3000,https://your-domain.com
ALLOWED_ORIGINS=http://localhost:3000

# ── Server ───────────────────────────────────────────────────
# FastAPI server host and port
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend URL (used by backend to serve previews)
FRONTEND_URL=http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────────
# Max personalize requests per minute per client_id
RATE_LIMIT_PERSONALIZE=3

# Max token requests per minute per IP
RATE_LIMIT_AUTH=20

# ── Caching ──────────────────────────────────────────────────
# Cache TTL in seconds (default 1 hour)
CACHE_TTL=3600

# ── Page Fetcher ──────────────────────────────────────────────
# HTTP timeout in seconds for fetching landing pages
FETCH_TIMEOUT=5

# Max retry attempts for failed fetches
FETCH_MAX_RETRIES=3
